{
  "name": "crypto-market-monitor",
  "version": "1.0.0",
  "description": "Real-time crypto market monitoring with Kafka and MongoDB",
  "main": "ingestion/binance-producer.js",
  "scripts": {
    "producers": "concurrently \"node ingestion/binance-producer.js\" \"node ingestion/coinbase-producer.js\"",
    "consumers": "concurrently \"node consumers/consumer1-parser.js\" \"node consumers/consumer2-aggregator.js\" \"node consumers/consumer3-anomaly.js\"",
    "server": "node server.js",
    "start": "concurrently \"npm run producers\" \"npm run consumers\" \"npm run server\""
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "kafkajs": "^2.2.4",
    "mongodb": "^6.5.0",
    "ws": "^8.17.0"
  }
}
